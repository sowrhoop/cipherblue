(typeattribute userns_container_privileged_file_type)
(typeattributeset userns_container_privileged_file_type (container_runtime_exec_t docker_exec_t kubelet_exec_t))

(typeattribute userns_container_relabel_allowed)
(typeattributeset userns_container_relabel_allowed (init_t initrc_t install_t kernel_t))

(typeattribute userns_container_relabel_restricted)
(typeattributeset userns_container_relabel_restricted (and (domain) (not (userns_container_relabel_allowed))))

(deny userns_container_relabel_restricted userns_container_privileged_file_type (blk_file (relabelfrom relabelto)))
(deny userns_container_relabel_restricted userns_container_privileged_file_type (chr_file (relabelfrom relabelto)))
(deny userns_container_relabel_restricted userns_container_privileged_file_type (dir (relabelfrom relabelto)))
(deny userns_container_relabel_restricted userns_container_privileged_file_type (fifo_file (relabelfrom relabelto)))
(deny userns_container_relabel_restricted userns_container_privileged_file_type (file (relabelfrom relabelto)))
(deny userns_container_relabel_restricted userns_container_privileged_file_type (lnk_file (relabelfrom relabelto)))
