[Unit]
Description=Cipherblue Flatpak State Enforcer
After=network-online.target systemd-resolved.service
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/bash /usr/libexec/cipherblue/cipher-flatpak-vault.sh

# If it fails (e.g., internet drops), try again in 30 seconds
Restart=on-failure
RestartSec=30s

[Install]
WantedBy=multi-user.target